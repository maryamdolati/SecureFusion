class FeatureLevelFusionMLP(nn.Module):
    def __init__(self, text_dim=TEXT_HIDDEN_SIZE, tab_dim=TAB_DMODEL):
        super().__init__()

        self.classifier = nn.Sequential(
            nn.Linear(text_dim + tab_dim, 256),
            nn.GELU(),
            nn.Dropout(0.30),
            nn.Linear(256, 64),
            nn.GELU(),
            nn.Dropout(0.20),
            nn.Linear(64, 1),
        )

    def forward(self, text_emb, tab_emb):
        z = torch.cat([text_emb, tab_emb], dim=1)
        return self.classifier(z).squeeze(-1)



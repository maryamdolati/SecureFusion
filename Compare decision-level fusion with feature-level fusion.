    if va["f1"] > best_ff_f1 + 1e-4:
        best_ff_f1 = va["f1"]
        ff_patience = 0
        torch.save(feature_fusion.state_dict(), ff_path)
        print("  saved best feature-level fusion")
    else:
        ff_patience += 1

        if ff_patience >= FEATURE_FUSION_PATIENCE:
            print("  feature-level fusion early stopping")
            break

feature_fusion.load_state_dict(torch.load(ff_path, map_location=DEVICE))
feature_fusion.eval()

ff_va = run_feature_fusion_epoch(mm_va_loader, train=False)
ff_te = run_feature_fusion_epoch(mm_te_loader, train=False)

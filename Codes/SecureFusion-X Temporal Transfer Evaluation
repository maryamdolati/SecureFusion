    num_training_steps=num_steps,
)

best_student_f1 = -1
student_bad = 0

for epoch in range(1, STUDENT_MAX_EPOCHS + 1):
    student_model.train()
    losses = []

    for input_ids, attention_mask, labels in tqdm(text_train_loader, desc=f"Student epoch {epoch}", leave=False):
        input_ids = input_ids.to(DEVICE)
        attention_mask = attention_mask.to(DEVICE)
        labels = labels.to(DEVICE)

        if ROBUST_TEXT_TRAIN:
            input_ids, attention_mask = perturb_text_batch(input_ids, attention_mask, TEXT_PERTURB_PROB)

        with torch.no_grad():
            teacher_logits = teacher_model(input_ids, attention_mask)
            teacher_soft = torch.sigmoid(teacher_logits / DISTILL_TEMPERATURE)

        student_logits = student_model(input_ids, attention_mask)

        smooth_labels = labels * 0.90 + 0.5 * 0.10
        hard_loss = criterion_hard(student_logits, smooth_labels)
        soft_loss = criterion_soft(student_logits / DISTILL_TEMPERATURE, teacher_soft) * (DISTILL_TEMPERATURE ** 2)
        loss = ALPHA * hard_loss + (1 - ALPHA) * soft_loss

        opt_student.zero_grad()
        loss.backward()
        torch.nn.utils.clip_grad_norm_(student_model.parameters(), MAX_GRAD_NORM)
        opt_student.step()
        scheduler_student.step()

        losses.append(loss.item())

    va = eval_text_model(student_model, text_val_loader, criterion_hard)
    print(f"[Student][Epoch {epoch}] loss={np.mean(losses):.4f} val_f1_2023={va['f1']:.4f} val_roc={va['roc_auc']:.4f}")

    if va["f1"] > best_student_f1 + 1e-4:
        best_student_f1 = va["f1"]
        student_bad = 0

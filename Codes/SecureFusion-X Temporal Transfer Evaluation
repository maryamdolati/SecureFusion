def augment_meta(X, y):
    X_full = X.copy()
    X_miss_text = X.copy()
    X_miss_text[:, 0] = 0.5
    X_miss_tab = X.copy()
    X_miss_tab[:, 1] = 0.5
    return np.concatenate([X_full, X_miss_text, X_miss_tab], axis=0), np.concatenate([y, y, y], axis=0)

def fit_meta_lr(X_train, y_train, X_calib, y_calib):
    X_aug, y_aug = augment_meta(X_train, y_train)
    trials = []

    for C in [0.03, 0.1, 0.3, 1.0, 3.0, 10.0]:
        for class_weight in [None, "balanced"]:
            model = LogisticRegression(
                C=C,
                class_weight=class_weight,
                max_iter=2000,
                random_state=SEED,
                solver="lbfgs",
            )

            start = time.time()
            model.fit(X_aug, y_aug)
            fit_time = time.time() - start

            p_calib = model.predict_proba(X_calib)[:, 1]
            thr, calib_f1 = best_threshold(y_calib, p_calib)

            trials.append({
                "model": model,
                "C": C,
                "class_weight": str(class_weight),
                "threshold": thr,
                "calib_f1": calib_f1,
                "fit_time": fit_time,
            })

    return sorted(trials, key=lambda r: r["calib_f1"], reverse=True)[0]


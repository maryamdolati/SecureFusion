class PairFeatureDS(Dataset):
    def __init__(self, et, eb, y):
        self.et = et.astype(np.float32)
        self.eb = eb.astype(np.float32)
        self.y = y.astype(np.float32)

    def __len__(self):
        return len(self.y)

    def __getitem__(self, idx):
        return (
            torch.tensor(self.et[idx], dtype=torch.float32),
            torch.tensor(self.eb[idx], dtype=torch.float32),
            torch.tensor(self.y[idx], dtype=torch.float32),
        )


class AttentionFeatureFusion(nn.Module):
    def __init__(self, text_dim, tab_dim, d_model=128, heads=4):
        super().__init__()

        self.text_proj = nn.Linear(text_dim, d_model)
        self.tab_proj = nn.Linear(tab_dim, d_model)

        self.attn = nn.MultiheadAttention(
            embed_dim=d_model,
            num_heads=heads,
            dropout=0.10,
            batch_first=True,
        )

        self.norm = nn.LayerNorm(d_model)

        self.head = nn.Sequential(
            nn.Linear(2 * d_model, 128),
            nn.GELU(),
            nn.Dropout(0.20),
            nn.Linear(128, 1),
        )

    def forward(self, et, eb):
        ht = self.text_proj(et).unsqueeze(1)
        hb = self.tab_proj(eb).unsqueeze(1)

        tokens = torch.cat([ht, hb], dim=1)

        attended, _ = self.attn(tokens, tokens, tokens)
        attended = self.norm(attended + tokens)

        z = attended.reshape(attended.size(0), -1)

        return self.head(z).squeeze(-1)


def train_attention_fusion(
    et_tr,
    eb_tr,
    y_tr,
    et_va,
    eb_va,
    y_va,
    max_epochs=30,
    batch_size=64,
    lr=1e-3,
    patience=6,
):
    model = AttentionFeatureFusion(et_tr.shape[1], eb_tr.shape[1]).to(DEVICE)
    opt = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-4)
    crit = nn.BCEWithLogitsLoss()

    tr_loader = DataLoader(PairFeatureDS(et_tr, eb_tr, y_tr), batch_size=batch_size, shuffle=True)
    va_loader = DataLoader(PairFeatureDS(et_va, eb_va, y_va), batch_size=batch_size, shuffle=False)

    best_state = None
    best_f1 = -1.0
    bad = 0

    for ep in range(1, max_epochs + 1):
        model.train()

        for et, eb, yb in tr_loader:
            et = et.to(DEVICE)
            eb = eb.to(DEVICE)
            yb = yb.to(DEVICE)

            logits = model(et, eb)
            loss = crit(logits, yb)

            opt.zero_grad()
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()

        model.eval()
        va_probs = []

        with torch.no_grad():
            for et, eb, _ in va_loader:
                et = et.to(DEVICE)
                eb = eb.to(DEVICE)
                va_probs.append(torch.sigmoid(model(et, eb)).cpu().numpy())

        va_probs = np.concatenate(va_probs)
        _, va_f1 = best_threshold(y_va, va_probs)

        print(f"[Attention Feature Fusion][Epoch {ep}] val_f1={va_f1:.4f}")

        if va_f1 > best_f1 + 1e-4:
            best_f1 = va_f1
            bad = 0
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
        else:
            bad += 1
            if bad >= patience:
                print("Attention-based feature fusion early stopping")
                break

    if best_state is None:
        raise RuntimeError("Attention-based feature fusion did not produce a valid checkpoint.")

    model.load_state_dict(best_state)
    return model


def predict_attention(model, et, eb, batch_size=256):
    loader = DataLoader(
        PairFeatureDS(et, eb, np.zeros(len(et))),
        batch_size=batch_size,
        shuffle=False,
    )

    model.eval()
    probs = []

    with torch.no_grad():
        for xt, xb, _ in loader:
            xt = xt.to(DEVICE)
            xb = xb.to(DEVICE)
            probs.append(torch.sigmoid(model(xt, xb)).cpu().numpy())

    return np.concatenate(probs)



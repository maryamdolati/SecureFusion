    for k, v in metrics.items():
        if isinstance(v, float):
            print(f"{k}: {v:.4f}")
        else:
            print(f"{k}: {v}")


def corrupt_texts_missing(texts, ratio=0.30, seed=42):
    rng = np.random.default_rng(seed)
    out = np.array(texts, dtype=object).copy()
    n = len(out)
    k = int(round(ratio * n))

    if k <= 0:
        return out

    idx = rng.choice(n, size=k, replace=False)
    out[idx] = ""
    return out


def corrupt_texts_noisy(texts, doc_ratio=0.30, token_ratio=0.30, seed=42):
    rng = np.random.default_rng(seed)
    out = np.array(texts, dtype=object).copy()
    n = len(out)
    k_docs = int(round(doc_ratio * n))

    if k_docs <= 0:
        return out

    idx = rng.choice(n, size=k_docs, replace=False)

    for i in idx:
        tokens = str(out[i]).split()

        if len(tokens) == 0:
            continue

        k_tokens = max(1, int(round(token_ratio * len(tokens))))
        chosen = rng.choice(len(tokens), size=k_tokens, replace=False)

        for j in chosen:
            tokens[j] = "[UNK]"

        out[i] = " ".join(tokens)

    return out


class TextOnlyDS(Dataset):
    def __init__(self, texts):
        self.texts = list(texts)

    def __len__(self):
        return len(self.texts)

    def __getitem__(self, idx):
        return self.texts[idx]


def collate_text_only(batch):
    enc = text_tokenizer(
        list(batch),
        padding=True,
        truncation=True,
        max_length=MAX_LEN,
        return_tensors="pt",
    )
    return enc["input_ids"], enc["attention_mask"]


class TabDS(Dataset):
    def __init__(self, xnum, xcat):
        self.xnum = xnum.astype(np.float32)
        self.xcat = xcat.astype(np.int64)

    def __len__(self):
        return len(self.xnum)

    def __getitem__(self, idx):
        return {
            "num": torch.tensor(self.xnum[idx], dtype=torch.float32),
            "cat": torch.tensor(self.xcat[idx], dtype=torch.long),
        }


def extract_text_probs_embeddings(model, texts, batch_size=16):
    loader = DataLoader(
        TextOnlyDS(texts),
        batch_size=batch_size,
        shuffle=False,
        collate_fn=collate_text_only,
        num_workers=0,
    )

    model.eval()
    probs_all = []
    emb_all = []

    with torch.no_grad():
        for input_ids, attention_mask in loader:
            input_ids = input_ids.to(DEVICE)
            attention_mask = attention_mask.to(DEVICE)

            outputs = model.bert(input_ids=input_ids, attention_mask=attention_mask)
            cls = outputs.last_hidden_state[:, 0, :]

            logits = model.classifier(model.dropout(cls)).squeeze(-1)
            probs = torch.sigmoid(logits)

            probs_all.append(probs.detach().cpu().numpy())
            emb_all.append(cls.detach().cpu().numpy())

    return np.concatenate(probs_all), np.concatenate(emb_all)


def extract_tab_probs_embeddings(model, xnum, xcat, batch_size=256):
    loader = DataLoader(
        TabDS(xnum, xcat),
        batch_size=batch_size,
        shuffle=False,
        num_workers=0,
    )

    model.eval()
    probs_all = []
    emb_all = []

    with torch.no_grad():
        for b in loader:
            xn = b["num"].to(DEVICE)
            xc = b["cat"].to(DEVICE)

            h = model.backbone(xn, xc)
            logits = model.head(h).squeeze(-1)
            probs = torch.sigmoid(logits)

            probs_all.append(probs.detach().cpu().numpy())
            emb_all.append(h.detach().cpu().numpy())

    return np.concatenate(probs_all), np.concatenate(emb_all)



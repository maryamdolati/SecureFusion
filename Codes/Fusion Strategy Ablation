class FusionArrayDS(Dataset):
    def __init__(self, X, y):
        self.X = X.astype(np.float32)
        self.y = y.astype(np.float32)

    def __len__(self):
        return len(self.y)

    def __getitem__(self, idx):
        return (
            torch.tensor(self.X[idx], dtype=torch.float32),
            torch.tensor(self.y[idx], dtype=torch.float32),
        )


class FeatureConcatMLP(nn.Module):
    def __init__(self, in_dim):
        super().__init__()

        self.net = nn.Sequential(
            nn.Linear(in_dim, 256),
            nn.GELU(),
            nn.Dropout(0.25),
            nn.Linear(256, 64),
            nn.GELU(),
            nn.Dropout(0.15),
            nn.Linear(64, 1),
        )

    def forward(self, x):
        return self.net(x).squeeze(-1)


def train_mlp_fusion(
    X_tr,
    y_tr,
    X_va,
    y_va,
    max_epochs=30,
    batch_size=64,
    lr=1e-3,
    patience=6,
):
    model = FeatureConcatMLP(X_tr.shape[1]).to(DEVICE)
    opt = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-4)
    crit = nn.BCEWithLogitsLoss()

    tr_loader = DataLoader(FusionArrayDS(X_tr, y_tr), batch_size=batch_size, shuffle=True)
    va_loader = DataLoader(FusionArrayDS(X_va, y_va), batch_size=batch_size, shuffle=False)

    best_state = None
    best_f1 = -1.0
    bad = 0

    for ep in range(1, max_epochs + 1):
        model.train()

        for xb, yb in tr_loader:
            xb = xb.to(DEVICE)
            yb = yb.to(DEVICE)

            logits = model(xb)
            loss = crit(logits, yb)

            opt.zero_grad()
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()

        model.eval()
        va_probs = []

        with torch.no_grad():
            for xb, _ in va_loader:
                xb = xb.to(DEVICE)
                va_probs.append(torch.sigmoid(model(xb)).cpu().numpy())

        va_probs = np.concatenate(va_probs)
        _, va_f1 = best_threshold(y_va, va_probs)

        print(f"[Feature Concat Fusion][Epoch {ep}] val_f1={va_f1:.4f}")

        if va_f1 > best_f1 + 1e-4:
            best_f1 = va_f1
            bad = 0
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
        else:
            bad += 1
            if bad >= patience:
                print("Feature-level concatenation early stopping")
                break

    if best_state is None:
        raise RuntimeError("Feature-level concatenation did not produce a valid checkpoint.")

    model.load_state_dict(best_state)
    return model


def predict_mlp(model, X, batch_size=256):
    loader = DataLoader(
        FusionArrayDS(X, np.zeros(len(X))),
        batch_size=batch_size,
        shuffle=False,
    )

    model.eval()
    probs = []

    with torch.no_grad():
        for xb, _ in loader:
            xb = xb.to(DEVICE)
            probs.append(torch.sigmoid(model(xb)).cpu().numpy())

    return np.concatenate(probs)



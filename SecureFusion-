def cat_cards_from_arrays(*arrs):
    if not arrs or arrs[0].shape[1] == 0: return []
    J = arrs[0].shape[1]; cards=[]
    for j in range(J):
        mx=0
        for A in arrs:
            if A.shape[1] > 0 and A.shape[0] > 0:
                mx=max(mx, int(np.max(A[:,j])))
        cards.append(mx+1)
    return cards


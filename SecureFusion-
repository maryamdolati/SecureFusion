import shap

def student_predict(text_list):
  
    enc = text_tokenizer(
        text_list,
        padding=True,
        truncation=True,
        max_length=MAX_LEN,
        return_tensors="pt"
    )
    input_ids = enc["input_ids"].to(DEVICE)
    attention_mask = enc["attention_mask"].to(DEVICE)

    with torch.no_grad():
        logits = student_model(input_ids, attention_mask)
        probs = torch.sigmoid(logits).cpu().numpy().reshape(-1, 1)
    return probs


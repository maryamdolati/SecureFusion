def run_tab_epoch(loader, train=True):
    tab_model.train() if train else tab_model.eval()
    losses=[]; all_logits=[]; all_y=[]
    for b in loader:
        xn = b["num"].to(DEVICE); xc = b["cat"].to(DEVICE); y = b["y"].to(DEVICE)

        if train and ROBUST_TAB_TRAIN:
            B = xn.size(0)
            mask = torch.rand(B, device=xn.device) < TAB_PERTURB_PROB
            idx = torch.nonzero(mask).squeeze(-1)
            if idx.numel() > 0:
                idx = idx[torch.randperm(idx.numel())]
                half = idx.numel() // 2
                miss_idx = idx[:half]
                noisy_idx = idx[half:]
                
                if miss_idx.numel() > 0:
                    if xn.shape[1] > 0:
                        xn[miss_idx] = 0.0
                    if xc.shape[1] > 0:
                        xc[miss_idx] = 0
                
                if noisy_idx.numel() > 0 and xn.shape[1] > 0:
                    noise = torch.randn_like(xn[noisy_idx]) * TAB_NOISE_STD
                    xn[noisy_idx] = xn[noisy_idx] + noise
       
        with torch.set_grad_enabled(train):
            logits = tab_model(xn, xc).squeeze(-1)
            loss = tab_crit(logits, y)
            if train:
                tab_optim.zero_grad()
                loss.backward()
                torch.nn.utils.clip_grad_norm_(tab_model.parameters(), MAX_GRAD_NORM)
                tab_optim.step()
        losses.append(loss.item())
        all_logits.append(logits.detach().cpu())
        all_y.append(y.detach().cpu())
    logits = torch.cat(all_logits)
    y = torch.cat(all_y).numpy()
    probs = torch.sigmoid(logits).numpy()
    preds = (probs>=0.5).astype(int)
    return float(np.mean(losses)), accuracy_score(y, preds), f1_score(y, preds), probs


def create_loader(probs_t, probs_b, y, batch=64, shuffle=True):
    X = np.vstack([probs_t, probs_b]).T.astype(np.float32)
    ds = torch.utils.data.TensorDataset(
        torch.tensor(X),
        torch.tensor(y).float()
    )
    return DataLoader(ds, batch_size=batch, shuffle=shuffle)


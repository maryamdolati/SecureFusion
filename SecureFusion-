def parse_cvss_v3(s):
    out={}
    if not isinstance(s,str) or "CVSS:3" not in s:
        return out
    for p in s.split("/"):
        if ":" in p:
            k,v=p.split(":",1); k=k.strip(); v=v.strip()
            if k in {"AV","AC","PR","UI","S","C","I","A"}:
                out[f"CVSSv3_{k}"]=v
    return out

def parse_cvss_v2(s):
    out={}
    if not isinstance(s,str):
        return out
    for p in s.split("/"):
        if ":" in p:
            k,v=p.split(":",1); k=k.strip(); v=v.strip()
            if k in {"AV","AC","Au","C","I","A"}:
                out[f"CVSSv2_{k}"]=v
    return out

